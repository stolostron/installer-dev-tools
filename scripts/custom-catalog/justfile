# Mode selection: MCH (multiclusterhub) or MCE (multicluster-engine)
# Set MODE=MCE for multicluster-engine operations, defaults to MCH
#
# Usage examples:
#   MCH (default): just e2e-catalog myuser release-2.16 latest-2.16 mytag
#   MCE:           MODE=MCE just e2e-catalog myuser release-2.6 latest-2.6 mytag
#
export MODE := env_var_or_default("MODE", "MCH")

# Configuration based on MODE
OPERATOR_REPO := if MODE == "MCE" { "https://github.com/cameronmwall/backplane-operator.git" } else { "https://github.com/stolostron/multiclusterhub-operator.git" }
OPERATOR_DIR := if MODE == "MCE" { "backplane-operator" } else { "multiclusterhub-operator" }
BUNDLE_REPO := if MODE == "MCE" { "https://github.com/stolostron/mce-operator-bundle.git" } else { "https://github.com/stolostron/acm-operator-bundle.git" }
CATALOG_BASE := if MODE == "MCE" { "quay.io/acm-d/mce-dev-catalog" } else { "quay.io/acm-d/acm-dev-catalog" }

# Clone operator repository (MCH or MCE based on MODE)
clone-operator BRANCH="main":
    #!/usr/bin/env bash
    echo "Mode: {{MODE}}"
    echo "Operator repo: {{OPERATOR_REPO}}"
    echo "Target directory: {{OPERATOR_DIR}}"

    # Use absolute path from justfile directory
    OPERATOR_PATH="{{justfile_directory()}}/{{OPERATOR_DIR}}"

    if [ -d "$OPERATOR_PATH" ]; then
        echo "Repository already exists at $OPERATOR_PATH"
        echo "Updating repository..."
        cd "$OPERATOR_PATH" && git fetch origin && git checkout {{BRANCH}} && git pull
    else
        echo "Cloning operator repository..."
        # cd {{justfile_directory()}} && git clone -b {{BRANCH}} {{OPERATOR_REPO}} {{OPERATOR_DIR}}
        cd {{justfile_directory()}} && git clone -b capi-changes {{OPERATOR_REPO}} {{OPERATOR_DIR}}
    fi
    echo "✓ Repository ready at $OPERATOR_PATH"

# Legacy alias for backward compatibility
clone-mch-operator BRANCH="main": (clone-operator BRANCH)

# Show current MODE configuration
info:
    @echo "Current MODE: {{MODE}}"
    @echo "Operator Repo: {{OPERATOR_REPO}}"
    @echo "Operator Dir: {{OPERATOR_DIR}}"
    @echo "Bundle Repo: {{BUNDLE_REPO}}"
    @echo "Catalog Base: {{CATALOG_BASE}}"

# Check if logged into quay.io with podman
_check-quay-login:
    #!/usr/bin/env bash
    if ! podman login --get-login quay.io &>/dev/null; then
        echo "Error: Not logged into quay.io. Please run: podman login quay.io"
        exit 1
    fi

# Install Python requirements for bundle automation in a virtual environment
_install-requirements:
    [ -d .venv ] || python3 -m venv .venv
    .venv/bin/pip install -r hack/bundle-automation/requirements.txt

# Regenerates charts, processing them through the Installer Chart Automation
# COMPONENT_BRANCHES: Optional component branch overrides in format "component1:branch1 component2:branch2"
# COMPONENT_FORKS: Optional component fork overrides in format "component1:git_url1 component2:git_url2"
regenerate-charts ORG="stolostron" REPO="installer-dev-tools" BRANCH="main" PIPELINE_REPO="pipeline" PIPELINE_BRANCH="2.17-integration" COMPONENT_BRANCHES="" COMPONENT_FORKS="": _install-requirements
    #!/usr/bin/env bash
    source .venv/bin/activate

    # Build component-branch arguments
    COMPONENT_ARGS=""
    if [ -n "{{COMPONENT_BRANCHES}}" ]; then
        for override in {{COMPONENT_BRANCHES}}; do
            COMPONENT_ARGS="$COMPONENT_ARGS --component-branch $override"
        done
    fi

    # Build component-fork arguments
    if [ -n "{{COMPONENT_FORKS}}" ]; then
        for override in {{COMPONENT_FORKS}}; do
            COMPONENT_ARGS="$COMPONENT_ARGS --component-fork $override"
        done
    fi

    python3 ./hack/bundle-automation/generate-shell.py \
        --update-charts \
        --org {{ORG}} \
        --repo {{REPO}} \
        --branch {{BRANCH}} \
        --pipeline-repo {{PIPELINE_REPO}} \
        --pipeline-branch {{PIPELINE_BRANCH}} \
        $COMPONENT_ARGS


# Copy existing Helm charts to pkg/templates/
copy-charts ORG="stolostron" REPO="installer-dev-tools" BRANCH="main": _install-requirements
    source .venv/bin/activate && python3 ./hack/bundle-automation/generate-shell.py \
        --copy-charts \
        --org "{{ORG}}" \
        --repo "{{REPO}}" \
        --branch "{{BRANCH}}"

# Build Operator image
operator-build IMG BRANCH="main": (clone-operator BRANCH)
    podman build --no-cache -t {{IMG}} {{justfile_directory()}}/{{OPERATOR_DIR}}

# Push Operator image
operator-push IMG:
    podman push {{IMG}}

# Build and Push Operator image
operator-build-and-push IMG BRANCH="main":
    @just operator-build {{IMG}} {{BRANCH}}
    @just operator-push {{IMG}}

# Build bundle image
bundle-build OPERATOR_IMAGE BUNDLE_IMAGE BRANCH="release-2.16" DISPLAY_NAME="Custom Catalog":
    #!/usr/bin/env bash

    # temp dir
    TMPDIR=$(mktemp -d)

    # Set bundle directory name based on MODE
    if [ "{{MODE}}" == "MCE" ]; then
        BUNDLE_DIR="mce-operator-bundle"
        CSV_PATTERN="multicluster-engine.v"
    else
        BUNDLE_DIR="acm-operator-bundle"
        CSV_PATTERN="advanced-cluster-management.v"
    fi

    # git clone branch
    echo "Cloning bundle repo: {{BUNDLE_REPO}}"
    git clone -b {{BRANCH}} {{BUNDLE_REPO}} "$TMPDIR/$BUNDLE_DIR"

    # replace quay.io with quay.io:443 to make sure it's there
    CSV_FILE=$(ls "$TMPDIR/$BUNDLE_DIR/manifests/${CSV_PATTERN}"*.clusterserviceversion.yaml)
    OPERATOR_IMAGE="{{OPERATOR_IMAGE}}"
    OPERATOR_IMAGE_WITH_PORT="${OPERATOR_IMAGE//quay.io/quay.io:443}"

    # replace the CSV operator image with the specified one
    echo "ℹ️  Replacing operator image in CSV with $OPERATOR_IMAGE_WITH_PORT"
    yq -i '.spec.install.spec.deployments[0].spec.template.spec.containers[0].image = "'"$OPERATOR_IMAGE_WITH_PORT"'"' "$CSV_FILE"

    # set display name
    echo "ℹ️  Setting display name to {{DISPLAY_NAME}}"
    yq -i '.spec.displayName = "{{DISPLAY_NAME}}"' "$CSV_FILE"

    echo "Validating Bundle"
    operator-sdk bundle validate "$TMPDIR/$BUNDLE_DIR"

    echo "Building Bundle Image"
    podman build -t {{BUNDLE_IMAGE}} "$TMPDIR/$BUNDLE_DIR"

#

# Push bundle image
bundle-push BUNDLE_IMAGE: _check-quay-login
    podman push {{BUNDLE_IMAGE}}

# Build and push bundle image
bundle-build-and-push OPERATOR_IMAGE BUNDLE_IMAGE BRANCH="release-2.16" DISPLAY_NAME="":
    #!/usr/bin/env bash
    # Set default display name based on MODE if not provided
    if [ -z "{{DISPLAY_NAME}}" ]; then
        if [ "{{MODE}}" == "MCE" ]; then
            DISPLAY_NAME="Custom MCE Catalog"
        else
            DISPLAY_NAME="Custom ACM Catalog"
        fi
    else
        DISPLAY_NAME="{{DISPLAY_NAME}}"
    fi
    just bundle-build "{{OPERATOR_IMAGE}}" "{{BUNDLE_IMAGE}}" "{{BRANCH}}" "$DISPLAY_NAME"
    just bundle-push "{{BUNDLE_IMAGE}}"


# Build the Catalog for Version, and then opm render the IMG on top of it
catalog-build VERSION BUNDLE_IMG CATALOG_IMG: _check-quay-login
    #!/usr/bin/env bash
    set -e

    TMPDIR=$(mktemp -d)
    echo "Temp dir: $TMPDIR"
    echo "Mode: {{MODE}}"

    # Set catalog directory name based on MODE
    if [ "{{MODE}}" == "MCE" ]; then
        CATALOG_DIR="multicluster-engine"
    else
        CATALOG_DIR="advanced-cluster-management"
    fi

    # Pull base catalog
    BASE_CATALOG="{{CATALOG_BASE}}:{{VERSION}}"
    echo "Pulling base catalog: $BASE_CATALOG"
    podman create --name temp-catalog docker://$BASE_CATALOG
    podman cp temp-catalog:/configs/$CATALOG_DIR $TMPDIR
    podman rm temp-catalog

    # Append the new bundle to bundles.yaml (don't remove old bundles)
    BUNDLES_FILE="$TMPDIR/$CATALOG_DIR/bundles.yaml"
    CHANNELS_FILE="$TMPDIR/$CATALOG_DIR/channels.yaml"

    echo "---" >> "$BUNDLES_FILE"
    opm render {{BUNDLE_IMG}} -oyaml | yq '(.image, .relatedImages[].image) |= sub("quay.io/", "quay.io:443/")' >> "$BUNDLES_FILE"

    # Extract the new bundle name from the rendered output
    NEW_BUNDLE_NAME=$(yq eval 'select(.schema == "olm.bundle") | .name' "$BUNDLES_FILE" | tail -1)
    echo "New bundle name: $NEW_BUNDLE_NAME"

    # Determine the channel name based on version
    if [ "{{MODE}}" == "MCE" ]; then
        # Extract version like 2.17 from the VERSION parameter (e.g., latest-2.17 -> 2.17)
        CHANNEL_VERSION=$(echo "{{VERSION}}" | grep -oP '\d+\.\d+' | head -1)
        CHANNEL_NAME="stable-${CHANNEL_VERSION}"
    else
        # For ACM, extract similarly
        CHANNEL_VERSION=$(echo "{{VERSION}}" | grep -oP '\d+\.\d+' | head -1)
        CHANNEL_NAME="release-${CHANNEL_VERSION}"
    fi
    echo "Target channel: $CHANNEL_NAME"

    # Get the previous bundle name from the channel
    PREV_BUNDLE_NAME=$(yq eval "select(.name == \"$CHANNEL_NAME\") | .entries[-1].name" "$CHANNELS_FILE")
    echo "Previous bundle: $PREV_BUNDLE_NAME"

    # Add the new bundle to the channel
    yq eval -i "(select(.name == \"$CHANNEL_NAME\") | .entries) += [{\"name\": \"$NEW_BUNDLE_NAME\", \"replaces\": \"$PREV_BUNDLE_NAME\"}]" "$CHANNELS_FILE"

    echo "Validating Catalog"
    opm validate "$TMPDIR/$CATALOG_DIR"

    echo "Generating Dockerfile"
    opm generate dockerfile "$TMPDIR/$CATALOG_DIR"

    echo "Building Catalog Image"
    podman build -f "$TMPDIR/$CATALOG_DIR.Dockerfile" -t {{CATALOG_IMG}} "$TMPDIR"

#

catalog-push CATALOG_IMG: _check-quay-login
    podman push {{CATALOG_IMG}}

catalog-build-and-push VERSION BUNDLE_IMG CATALOG_IMG:
    just catalog-build "{{VERSION}}" "{{BUNDLE_IMG}}" "{{CATALOG_IMG}}"
    just catalog-push "{{CATALOG_IMG}}"

# End-to-end build operator, bundle, and catalog (USERNAME: quay.io username, VERSION: bundle branch e.g. release-2.16, UPSTREAM_TAG: base catalog tag e.g. latest-2.16, TAG: custom tag for all images, OPERATOR_BRANCH: operator branch)
e2e-catalog USERNAME VERSION UPSTREAM_TAG TAG OPERATOR_BRANCH="main":
    #!/usr/bin/env bash
    echo "Mode: {{MODE}}"

    # Set image names based on MODE
    if [ "{{MODE}}" == "MCE" ]; then
        OPERATOR_IMAGE="quay.io/{{USERNAME}}/backplane-operator:{{TAG}}"
        BUNDLE_IMAGE="quay.io/{{USERNAME}}/mce-operator-bundle:{{TAG}}"
        CATALOG_IMAGE="quay.io/{{USERNAME}}/mce-dev-catalog:{{TAG}}"
    else
        OPERATOR_IMAGE="quay.io/{{USERNAME}}/multiclusterhub-operator:{{TAG}}"
        BUNDLE_IMAGE="quay.io/{{USERNAME}}/acm-operator-bundle:{{TAG}}"
        CATALOG_IMAGE="quay.io/{{USERNAME}}/acm-dev-catalog:{{TAG}}"
    fi

    just operator-build-and-push "$OPERATOR_IMAGE" "{{OPERATOR_BRANCH}}"
    just bundle-build-and-push "$OPERATOR_IMAGE" "$BUNDLE_IMAGE" "{{VERSION}}"
    just catalog-build-and-push "{{UPSTREAM_TAG}}" "$BUNDLE_IMAGE" "$CATALOG_IMAGE"

    echo ""
    echo "========================================="
    echo "Cleaning up cloned repositories"
    echo "========================================="
    cd {{justfile_directory()}}
    rm -rf {{OPERATOR_DIR}}
    echo "✓ Cleanup complete"

    echo ""
    echo "========================================="
    echo "✓ E2E catalog build complete!"
    echo "========================================="
    echo "Operator: $OPERATOR_IMAGE"
    echo "Bundle:   $BUNDLE_IMAGE"
    echo "Catalog:  $CATALOG_IMAGE"

# Dev workflow: Regenerate charts with component branch overrides, then build full e2e catalog
# COMPONENT_BRANCHES: Space-separated component branch overrides, e.g. "search-operator:my-branch observability:feature-x"
# COMPONENT_FORKS: Space-separated component fork overrides, e.g. "search-operator:https://github.com/user/search-operator.git observability:https://github.com/user/observability.git"
dev-branch-e2e USERNAME VERSION UPSTREAM_TAG TAG OPERATOR_BRANCH="main" COMPONENT_BRANCHES="" COMPONENT_FORKS="" ORG="stolostron" REPO="installer-dev-tools" BRANCH="main" PIPELINE_REPO="pipeline" PIPELINE_BRANCH="2.17-integration": (clone-operator OPERATOR_BRANCH)
    #!/usr/bin/env bash
    set -e

    echo "========================================="
    echo "Mode: {{MODE}}"
    echo "Operator directory: {{OPERATOR_DIR}}"
    echo "========================================="
    echo ""
    echo "========================================="
    echo "Step 1: Regenerating charts with component branch overrides"
    echo "========================================="

    # Navigate to operator repo (using absolute path from justfile directory)
    cd {{justfile_directory()}}/{{OPERATOR_DIR}}

    # Install Python requirements if needed
    if [ ! -d .venv ]; then
        python3 -m venv .venv
    fi
    .venv/bin/pip install -q -r hack/bundle-automation/requirements.txt 2>/dev/null || true

    # Build component-branch arguments
    COMPONENT_ARGS=""
    if [ -n "{{COMPONENT_BRANCHES}}" ]; then
        echo "Component branch overrides: {{COMPONENT_BRANCHES}}"
        for override in {{COMPONENT_BRANCHES}}; do
            COMPONENT_ARGS="$COMPONENT_ARGS --component-branch $override"
        done
    fi

    # Build component-fork arguments
    if [ -n "{{COMPONENT_FORKS}}" ]; then
        echo "Component fork overrides: {{COMPONENT_FORKS}}"
        for override in {{COMPONENT_FORKS}}; do
            COMPONENT_ARGS="$COMPONENT_ARGS --component-fork $override"
        done
    fi

    # Run the chart generation
    source .venv/bin/activate && python3 ./hack/bundle-automation/generate-shell.py \
        --update-charts \
        --org {{ORG}} \
        --repo {{REPO}} \
        --branch {{BRANCH}} \
        --pipeline-repo {{PIPELINE_REPO}} \
        --pipeline-branch {{PIPELINE_BRANCH}} \
        $COMPONENT_ARGS

    # Return to justfile directory
    cd {{justfile_directory()}}

    echo ""
    echo "========================================="
    echo "Step 2: Building and pushing operator image"
    echo "========================================="

    # Build and push the operator (image name based on MODE)
    if [ "{{MODE}}" == "MCE" ]; then
        OPERATOR_IMAGE="quay.io/{{USERNAME}}/backplane-operator:{{TAG}}"
        BUNDLE_IMAGE="quay.io/{{USERNAME}}/mce-operator-bundle:{{TAG}}"
        CATALOG_IMAGE="quay.io/{{USERNAME}}/mce-dev-catalog:{{TAG}}"
    else
        OPERATOR_IMAGE="quay.io/{{USERNAME}}/multiclusterhub-operator:{{TAG}}"
        BUNDLE_IMAGE="quay.io/{{USERNAME}}/acm-operator-bundle:{{TAG}}"
        CATALOG_IMAGE="quay.io/{{USERNAME}}/acm-dev-catalog:{{TAG}}"
    fi

    just operator-build-and-push "$OPERATOR_IMAGE" "{{OPERATOR_BRANCH}}"

    echo ""
    echo "========================================="
    echo "Step 3: Building and pushing bundle image"
    echo "========================================="

    # Build and push the bundle
    just bundle-build-and-push "$OPERATOR_IMAGE" "$BUNDLE_IMAGE" "{{VERSION}}"

    echo ""
    echo "========================================="
    echo "Step 4: Building and pushing catalog image"
    echo "========================================="

    # Build and push the catalog
    just catalog-build-and-push "{{UPSTREAM_TAG}}" "$BUNDLE_IMAGE" "$CATALOG_IMAGE"

    echo ""
    echo "========================================="
    echo "Cleaning up cloned repositories"
    echo "========================================="
    cd {{justfile_directory()}}
    rm -rf {{OPERATOR_DIR}}
    echo "✓ Cleanup complete"

    echo ""
    echo "========================================="
    echo "✓ Dev branch e2e complete!"
    echo "========================================="
    echo "Operator: $OPERATOR_IMAGE"
    echo "Bundle:   $BUNDLE_IMAGE"
    echo "Catalog:  $CATALOG_IMAGE"