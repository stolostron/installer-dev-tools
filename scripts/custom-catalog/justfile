# Build bundle image
[arg("OPERATOR_IMAGE", long="operator-image")]
[arg("BUNDLE_IMAGE", long="bundle-image")]
[arg("BRANCH", long="branch")]
[arg("DISPLAY_NAME", long="display-name")]
[arg("mode", long="mode")]
[arg("bundle_repo", long="bundle-repo")]
[arg("use_https", long="use-https", value="true")]
[arg("additional_images", long="additional-images")]
bundle-build OPERATOR_IMAGE BUNDLE_IMAGE BRANCH="release-2.16" DISPLAY_NAME="Custom Catalog" mode="MCH" bundle_repo="" use_https="false" additional_images="":
    #!/usr/bin/env bash

    # temp dir
    TMPDIR=$(mktemp -d)

    # Set bundle directory name based on mode
    if [ "{{mode}}" == "MCE" ]; then
        BUNDLE_DIR="mce-operator-bundle"
        CSV_PATTERN="multicluster-engine.v"
    else
        BUNDLE_DIR="acm-operator-bundle"
        CSV_PATTERN="advanced-cluster-management.v"
    fi

    # Determine bundle repo URL
    if [ -n "{{bundle_repo}}" ]; then
        BUNDLE_REPO="{{bundle_repo}}"
    else
        if [ "{{mode}}" == "MCE" ]; then
            if [ "{{use_https}}" == "true" ]; then
                BUNDLE_REPO="https://github.com/stolostron/mce-operator-bundle.git"
            else
                BUNDLE_REPO="git@github.com:stolostron/mce-operator-bundle.git"
            fi
        else
            if [ "{{use_https}}" == "true" ]; then
                BUNDLE_REPO="https://github.com/stolostron/acm-operator-bundle.git"
            else
                BUNDLE_REPO="git@github.com:stolostron/acm-operator-bundle.git"
            fi
        fi
    fi

    # git clone branch
    echo "Cloning bundle repo: $BUNDLE_REPO"
    git clone -b {{BRANCH}} "$BUNDLE_REPO" "$TMPDIR/$BUNDLE_DIR"

    # replace quay.io with quay.io:443 to make sure it's there
    CSV_FILE=$(ls "$TMPDIR/$BUNDLE_DIR/manifests/${CSV_PATTERN}"*.clusterserviceversion.yaml)
    OPERATOR_IMAGE="{{OPERATOR_IMAGE}}"
    OPERATOR_IMAGE_WITH_PORT="${OPERATOR_IMAGE//quay.io/quay.io:443}"

    # replace the CSV operator image with the specified one
    echo "ℹ️  Replacing operator image in CSV with $OPERATOR_IMAGE_WITH_PORT"
    yq -i '.spec.install.spec.deployments[0].spec.template.spec.containers[0].image = "'"$OPERATOR_IMAGE_WITH_PORT"'"' "$CSV_FILE"

    # replace additional component images if specified
    if [ -n "{{additional_images}}" ]; then
        IFS=',' read -ra OVERRIDES <<< "{{additional_images}}"
        for override in "${OVERRIDES[@]}"; do
            image_key="${override%%=*}"
            image_value="${override#*=}"
            image_value_with_port="${image_value/quay.io\//quay.io:443/}"
            echo "ℹ️  Replacing $image_key with $image_value_with_port"

            # Replace in relatedImages
            yq -i "(.spec.relatedImages[] | select(.name == \"$image_key\") | .image) = \"$image_value_with_port\"" "$CSV_FILE"

            # Replace in deployment env vars (OPERAND_IMAGE_* pattern)
            env_var_name="OPERAND_IMAGE_${image_key^^}"
            echo "ℹ️  Replacing env var $env_var_name with $image_value_with_port"
            yq -i "(.spec.install.spec.deployments[].spec.template.spec.containers[].env[] | select(.name == \"$env_var_name\") | .value) = \"$image_value_with_port\"" "$CSV_FILE"
        done
    fi

    # set display name
    echo "ℹ️  Setting display name to {{DISPLAY_NAME}}"
    yq -i '.spec.displayName = "{{DISPLAY_NAME}}"' "$CSV_FILE"

    echo "Validating Bundle"
    operator-sdk bundle validate "$TMPDIR/$BUNDLE_DIR"

    echo "Building Bundle Image"
    podman build -t {{BUNDLE_IMAGE}} "$TMPDIR/$BUNDLE_DIR"

#

# Push bundle image
[arg("BUNDLE_IMAGE", long="bundle-image")]
bundle-push BUNDLE_IMAGE: _check-quay-login
    podman push {{BUNDLE_IMAGE}}

# Build and push bundle image
[arg("OPERATOR_IMAGE", long="operator-image")]
[arg("BUNDLE_IMAGE", long="bundle-image")]
[arg("BRANCH", long="branch")]
[arg("DISPLAY_NAME", long="display-name")]
[arg("mode", long="mode")]
[arg("bundle_repo", long="bundle-repo")]
[arg("use_https", long="use-https", value="true")]
[arg("additional_images", long="additional-images")]
bundle-build-and-push OPERATOR_IMAGE BUNDLE_IMAGE BRANCH="release-2.16" DISPLAY_NAME="" mode="MCH" bundle_repo="" use_https="false" additional_images="":
    #!/usr/bin/env bash
    # Set default display name based on mode if not provided
    if [ -z "{{DISPLAY_NAME}}" ]; then
        if [ "{{mode}}" == "MCE" ]; then
            DISPLAY_NAME="Custom MCE Catalog"
        else
            DISPLAY_NAME="Custom ACM Catalog"
        fi
    else
        DISPLAY_NAME="{{DISPLAY_NAME}}"
    fi

    HTTPS_FLAG=""
    if [ "{{use_https}}" == "true" ]; then
        HTTPS_FLAG="--use-https"
    fi

    ADDITIONAL_IMAGES_FLAG=""
    if [ -n "{{additional_images}}" ]; then
        ADDITIONAL_IMAGES_FLAG="--additional-images \"{{additional_images}}\""
    fi

    just bundle-build --operator-image "{{OPERATOR_IMAGE}}" --bundle-image "{{BUNDLE_IMAGE}}" --branch "{{BRANCH}}" --display-name "$DISPLAY_NAME" --mode {{mode}} --bundle-repo "{{bundle_repo}}" $HTTPS_FLAG $ADDITIONAL_IMAGES_FLAG
    just bundle-push --bundle-image "{{BUNDLE_IMAGE}}"


# Build the Catalog for Version, and then opm render the IMG on top of it
[arg("BASE_CATALOG_TAG", long="base-catalog-tag")]
[arg("BUNDLE_IMG", long="bundle-img")]
[arg("CATALOG_IMG", long="catalog-img")]
[arg("mode", long="mode")]
[arg("catalog_base", long="catalog-base")]
catalog-build BASE_CATALOG_TAG BUNDLE_IMG CATALOG_IMG mode="MCH" catalog_base="": _check-quay-login
    #!/usr/bin/env bash
    set -e

    TMPDIR=$(mktemp -d)
    echo "Temp dir: $TMPDIR"
    echo "Mode: {{mode}}"

    # Set catalog directory name based on mode
    if [ "{{mode}}" == "MCE" ]; then
        CATALOG_DIR="multicluster-engine"
    else
        CATALOG_DIR="advanced-cluster-management"
    fi

    # Determine catalog base
    if [ -n "{{catalog_base}}" ]; then
        CATALOG_BASE="{{catalog_base}}"
    else
        if [ "{{mode}}" == "MCE" ]; then
            CATALOG_BASE="quay.io/acm-d/mce-dev-catalog"
        else
            CATALOG_BASE="quay.io/acm-d/acm-dev-catalog"
        fi
    fi

    # Pull base catalog
    BASE_CATALOG="$CATALOG_BASE:{{BASE_CATALOG_TAG}}"
    echo "Pulling base catalog: $BASE_CATALOG"
    podman create --replace --name temp-catalog docker://$BASE_CATALOG
    podman cp temp-catalog:/configs/$CATALOG_DIR $TMPDIR
    podman rm temp-catalog

    # Append the new bundle to bundles.yaml (don't remove old bundles)
    BUNDLES_FILE="$TMPDIR/$CATALOG_DIR/bundles.yaml"
    CHANNELS_FILE="$TMPDIR/$CATALOG_DIR/channels.yaml"

    echo "---" >> "$BUNDLES_FILE"
    opm render {{BUNDLE_IMG}} -oyaml | yq '(.image, .relatedImages[].image) |= sub("quay.io/", "quay.io:443/")' >> "$BUNDLES_FILE"

    # Extract the new bundle name from the rendered output
    NEW_BUNDLE_NAME=$(yq eval 'select(.schema == "olm.bundle") | .name' "$BUNDLES_FILE" | tail -1)
    echo "New bundle name: $NEW_BUNDLE_NAME"

    # Determine the channel name based on version
    if [ "{{mode}}" == "MCE" ]; then
        # Extract version like 2.17 from the BASE_CATALOG_TAG parameter (e.g., latest-2.17 -> 2.17)
        CHANNEL_VERSION=$(echo "{{BASE_CATALOG_TAG}}" | grep -oP '\d+\.\d+' | head -1)
        CHANNEL_NAME="stable-${CHANNEL_VERSION}"
    else
        # For ACM, extract similarly
        CHANNEL_VERSION=$(echo "{{BASE_CATALOG_TAG}}" | grep -oP '\d+\.\d+' | head -1)
        CHANNEL_NAME="release-${CHANNEL_VERSION}"
    fi
    echo "Target channel: $CHANNEL_NAME"

    # Get the previous bundle name from the channel
    PREV_BUNDLE_NAME=$(yq eval "select(.name == \"$CHANNEL_NAME\") | .entries[-1].name" "$CHANNELS_FILE")
    echo "Previous bundle: $PREV_BUNDLE_NAME"

    # Add the new bundle to the channel
    yq eval -i "(select(.name == \"$CHANNEL_NAME\") | .entries) += [{\"name\": \"$NEW_BUNDLE_NAME\", \"replaces\": \"$PREV_BUNDLE_NAME\"}]" "$CHANNELS_FILE"

    echo "Validating Catalog"
    opm validate "$TMPDIR/$CATALOG_DIR"

    echo "Generating Dockerfile"
    opm generate dockerfile "$TMPDIR/$CATALOG_DIR"

    echo "Building Catalog Image"
    podman build -f "$TMPDIR/$CATALOG_DIR.Dockerfile" -t {{CATALOG_IMG}} "$TMPDIR"

#

[arg("CATALOG_IMG", long="catalog-img")]
catalog-push CATALOG_IMG: _check-quay-login
    podman push {{CATALOG_IMG}}

[arg("BASE_CATALOG_TAG", long="base-catalog-tag")]
[arg("BUNDLE_IMG", long="bundle-img")]
[arg("CATALOG_IMG", long="catalog-img")]
[arg("mode", long="mode")]
[arg("catalog_base", long="catalog-base")]
