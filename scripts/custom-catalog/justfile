    just catalog-build --base-catalog-tag "{{BASE_CATALOG_TAG}}" --bundle-img "{{BUNDLE_IMG}}" --catalog-img "{{CATALOG_IMG}}" --mode {{mode}} --catalog-base "{{catalog_base}}"
    just catalog-push --catalog-img "{{CATALOG_IMG}}"

# End-to-end build operator, bundle, and catalog
[arg("USERNAME", long="username")]
[arg("BUNDLE_BRANCH", long="bundle-branch")]
[arg("BASE_CATALOG_TAG", long="base-catalog-tag")]
[arg("IMAGE_TAG", long="image-tag")]
[arg("OPERATOR_BRANCH", long="operator-branch")]
[arg("mode", long="mode")]
[arg("operator_repo", long="operator-repo")]
[arg("bundle_repo", long="bundle-repo")]
[arg("catalog_base", long="catalog-base")]
[arg("use_https", long="use-https", value="true")]
[arg("additional_images", long="additional-images")]
e2e-catalog USERNAME BUNDLE_BRANCH BASE_CATALOG_TAG IMAGE_TAG OPERATOR_BRANCH="main" mode="MCH" operator_repo="" bundle_repo="" catalog_base="" use_https="false" additional_images="":
    #!/usr/bin/env bash
    echo "Mode: {{mode}}"

    # Determine operator directory based on mode
    if [ "{{mode}}" == "MCE" ]; then
        OPERATOR_DIR="backplane-operator"
    else
        OPERATOR_DIR="multiclusterhub-operator"
    fi

    # Set image names based on mode
    if [ "{{mode}}" == "MCE" ]; then
        OPERATOR_IMAGE="quay.io/{{USERNAME}}/backplane-operator:{{IMAGE_TAG}}"
        BUNDLE_IMAGE="quay.io/{{USERNAME}}/mce-operator-bundle:{{IMAGE_TAG}}"
        CATALOG_IMAGE="quay.io/{{USERNAME}}/mce-dev-catalog:{{IMAGE_TAG}}"
    else
        OPERATOR_IMAGE="quay.io/{{USERNAME}}/multiclusterhub-operator:{{IMAGE_TAG}}"
        BUNDLE_IMAGE="quay.io/{{USERNAME}}/acm-operator-bundle:{{IMAGE_TAG}}"
        CATALOG_IMAGE="quay.io/{{USERNAME}}/acm-dev-catalog:{{IMAGE_TAG}}"
    fi

    HTTPS_FLAG=""
    if [ "{{use_https}}" == "true" ]; then
        HTTPS_FLAG="--use-https"
    fi

    ADDITIONAL_IMAGES_FLAG=""
    if [ -n "{{additional_images}}" ]; then
        ADDITIONAL_IMAGES_FLAG="--additional-images \"{{additional_images}}\""
    fi

    just operator-build-and-push --img "$OPERATOR_IMAGE" --branch "{{OPERATOR_BRANCH}}" --mode {{mode}} --operator-repo "{{operator_repo}}" $HTTPS_FLAG
    just bundle-build-and-push --operator-image "$OPERATOR_IMAGE" --bundle-image "$BUNDLE_IMAGE" --branch "{{BUNDLE_BRANCH}}" --mode {{mode}} --bundle-repo "{{bundle_repo}}" $HTTPS_FLAG $ADDITIONAL_IMAGES_FLAG
    just catalog-build-and-push --base-catalog-tag "{{BASE_CATALOG_TAG}}" --bundle-img "$BUNDLE_IMAGE" --catalog-img "$CATALOG_IMAGE" --mode {{mode}} --catalog-base "{{catalog_base}}"

    # Uncomment to clean up cloned repository after build:
    # just cleanup-operator --mode {{mode}}

    echo ""
    echo "========================================="
    echo "✓ E2E catalog build complete!"
    echo "========================================="
    echo "Operator: $OPERATOR_IMAGE"
    echo "Bundle:   $BUNDLE_IMAGE"
    echo "Catalog:  $CATALOG_IMAGE"

# Dev workflow: Regenerate charts with component branch overrides, then build full e2e catalog
# COMPONENT_BRANCHES: Space-separated component branch overrides, e.g. "search-operator:my-branch observability:feature-x"
# COMPONENT_FORKS: Space-separated component fork overrides, e.g. "search-operator:https://github.com/user/search-operator.git observability:https://github.com/user/observability.git"
[arg("USERNAME", long="username")]
[arg("BUNDLE_BRANCH", long="bundle-branch")]
[arg("BASE_CATALOG_TAG", long="base-catalog-tag")]
[arg("IMAGE_TAG", long="image-tag")]
[arg("OPERATOR_BRANCH", long="operator-branch")]
[arg("COMPONENT_BRANCHES", long="component-branches")]
[arg("COMPONENT_FORKS", long="component-forks")]
[arg("ORG", long="org")]
[arg("REPO", long="repo")]
[arg("BRANCH", long="branch")]
[arg("PIPELINE_REPO", long="pipeline-repo")]
[arg("PIPELINE_BRANCH", long="pipeline-branch")]
[arg("mode", long="mode")]
[arg("operator_repo", long="operator-repo")]
[arg("bundle_repo", long="bundle-repo")]
[arg("catalog_base", long="catalog-base")]
[arg("use_https", long="use-https", value="true")]
[arg("additional_images", long="additional-images")]
dev-branch-e2e USERNAME BUNDLE_BRANCH BASE_CATALOG_TAG IMAGE_TAG OPERATOR_BRANCH="main" COMPONENT_BRANCHES="" COMPONENT_FORKS="" ORG="stolostron" REPO="installer-dev-tools" BRANCH="main" PIPELINE_REPO="pipeline" PIPELINE_BRANCH="2.17-integration" mode="MCH" operator_repo="" bundle_repo="" catalog_base="" use_https="false" additional_images="": (clone-operator OPERATOR_BRANCH mode operator_repo use_https)
    #!/usr/bin/env bash
    set -e

    # Determine operator directory based on mode
    if [ "{{mode}}" == "MCE" ]; then
        OPERATOR_DIR="backplane-operator"
    else
        OPERATOR_DIR="multiclusterhub-operator"
    fi

    echo "========================================="
    echo "Mode: {{mode}}"
    echo "Operator directory: $OPERATOR_DIR"
    echo "========================================="
    echo ""
    echo "========================================="
    echo "Step 1: Regenerating charts with component branch overrides"
    echo "========================================="

    # Navigate to operator repo (using absolute path from justfile directory)
    cd {{justfile_directory()}}/$OPERATOR_DIR

    # Install Python requirements if needed
    if [ ! -d .venv ]; then
        python3 -m venv .venv
    fi
    .venv/bin/pip install -q -r hack/bundle-automation/requirements.txt 2>/dev/null || true

    # Build component-branch arguments
    COMPONENT_ARGS=""
    if [ -n "{{COMPONENT_BRANCHES}}" ]; then
        echo "Component branch overrides: {{COMPONENT_BRANCHES}}"
        for override in {{COMPONENT_BRANCHES}}; do
            COMPONENT_ARGS="$COMPONENT_ARGS --component-branch $override"
        done
    fi

    # Build component-fork arguments
    if [ -n "{{COMPONENT_FORKS}}" ]; then
        echo "Component fork overrides: {{COMPONENT_FORKS}}"
        for override in {{COMPONENT_FORKS}}; do
            COMPONENT_ARGS="$COMPONENT_ARGS --component-fork $override"
        done
    fi

    # Run the chart generation
    source .venv/bin/activate && python3 ./hack/bundle-automation/generate-shell.py \
        --update-charts \
        --org {{ORG}} \
        --repo {{REPO}} \
        --branch {{BRANCH}} \
        --pipeline-repo {{PIPELINE_REPO}} \
        --pipeline-branch {{PIPELINE_BRANCH}} \
        $COMPONENT_ARGS

    # Return to justfile directory
    cd {{justfile_directory()}}

    echo ""
    echo "========================================="
    echo "Step 2: Building and pushing operator image"
    echo "========================================="

    # Build and push the operator (image name based on mode)
    if [ "{{mode}}" == "MCE" ]; then
        OPERATOR_IMAGE="quay.io/{{USERNAME}}/backplane-operator:{{IMAGE_TAG}}"
        BUNDLE_IMAGE="quay.io/{{USERNAME}}/mce-operator-bundle:{{IMAGE_TAG}}"
        CATALOG_IMAGE="quay.io/{{USERNAME}}/mce-dev-catalog:{{IMAGE_TAG}}"
    else
        OPERATOR_IMAGE="quay.io/{{USERNAME}}/multiclusterhub-operator:{{IMAGE_TAG}}"
        BUNDLE_IMAGE="quay.io/{{USERNAME}}/acm-operator-bundle:{{IMAGE_TAG}}"
        CATALOG_IMAGE="quay.io/{{USERNAME}}/acm-dev-catalog:{{IMAGE_TAG}}"
    fi

    HTTPS_FLAG=""
    if [ "{{use_https}}" == "true" ]; then
        HTTPS_FLAG="--use-https"
    fi

    ADDITIONAL_IMAGES_FLAG=""
    if [ -n "{{additional_images}}" ]; then
        ADDITIONAL_IMAGES_FLAG="--additional-images \"{{additional_images}}\""
    fi

    just operator-build-and-push --img "$OPERATOR_IMAGE" --branch "{{OPERATOR_BRANCH}}" --mode {{mode}} --operator-repo "{{operator_repo}}" $HTTPS_FLAG

    echo ""
    echo "========================================="
    echo "Step 3: Building and pushing bundle image"
    echo "========================================="

    # Build and push the bundle
    just bundle-build-and-push --operator-image "$OPERATOR_IMAGE" --bundle-image "$BUNDLE_IMAGE" --branch "{{BUNDLE_BRANCH}}" --mode {{mode}} --bundle-repo "{{bundle_repo}}" $HTTPS_FLAG $ADDITIONAL_IMAGES_FLAG

    echo ""
    echo "========================================="
    echo "Step 4: Building and pushing catalog image"
    echo "========================================="

    # Build and push the catalog
    just catalog-build-and-push --base-catalog-tag "{{BASE_CATALOG_TAG}}" --bundle-img "$BUNDLE_IMAGE" --catalog-img "$CATALOG_IMAGE" --mode {{mode}} --catalog-base "{{catalog_base}}"

    # Uncomment to clean up cloned repository after build:
    # just cleanup-operator --mode {{mode}}

    echo ""
    echo "========================================="
    echo "✓ Dev branch e2e complete!"
    echo "========================================="
    echo "Operator: $OPERATOR_IMAGE"
    echo "Bundle:   $BUNDLE_IMAGE"
    echo "Catalog:  $CATALOG_IMAGE"


