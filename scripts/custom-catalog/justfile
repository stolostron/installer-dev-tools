# Clone operator repository (MCH or MCE based on mode)
[arg("BRANCH", long="branch")]
[arg("mode", long="mode")]
[arg("operator_repo", long="operator-repo")]
[arg("use_https", long="use-https", value="true")]
clone-operator BRANCH="main" mode="MCH" operator_repo="" use_https="false":
    #!/usr/bin/env bash

    # Determine operator directory based on mode
    if [ "{{mode}}" == "MCE" ]; then
        OPERATOR_DIR="backplane-operator"
    else
        OPERATOR_DIR="multiclusterhub-operator"
    fi

    # Determine operator repo URL
    if [ -n "{{operator_repo}}" ]; then
        OPERATOR_REPO="{{operator_repo}}"
    else
        # Compute default based on mode and use_https
        if [ "{{mode}}" == "MCE" ]; then
            if [ "{{use_https}}" == "true" ]; then
                OPERATOR_REPO="https://github.com/stolostron/backplane-operator.git"
            else
                OPERATOR_REPO="git@github.com:stolostron/backplane-operator.git"
            fi
        else
            if [ "{{use_https}}" == "true" ]; then
                OPERATOR_REPO="https://github.com/stolostron/multiclusterhub-operator.git"
            else
                OPERATOR_REPO="git@github.com:stolostron/multiclusterhub-operator.git"
            fi
        fi
    fi

    echo "Mode: {{mode}}"
    echo "Operator repo: $OPERATOR_REPO"
    echo "Target directory: $OPERATOR_DIR"

    # Use absolute path from justfile directory
    OPERATOR_PATH="{{justfile_directory()}}/$OPERATOR_DIR"

    if [ -d "$OPERATOR_PATH" ]; then
        echo "Repository already exists at $OPERATOR_PATH"
        echo "Updating repository..."
        cd "$OPERATOR_PATH" && git fetch origin && git checkout {{BRANCH}} && git pull
    else
        echo "Cloning operator repository..."
        cd {{justfile_directory()}} && git clone -b {{BRANCH}} "$OPERATOR_REPO" "$OPERATOR_DIR"
    fi
    echo "✓ Repository ready at $OPERATOR_PATH"

